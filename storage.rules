rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function cmsEditor() {
      return signedIn()
        && request.auth.token.cmsAccess == true
        && request.auth.token.role in ["admin", "editor"];
    }

    function validImage(contentType) {
      return request.resource != null
        && request.resource.size < 3 * 1024 * 1024
        && request.resource.contentType == contentType;
    }

    function validAlphabetImage() {
      return request.resource != null
        && request.resource.size < 3 * 1024 * 1024
        && request.resource.contentType in ["image/webp", "image/svg+xml"];
    }

    match /cms/alphabet/{allPaths=**} {
      allow read: if true;
      allow write: if cmsEditor() && validAlphabetImage();
    }

    match /cms/{allPaths=**} {
      allow read: if true;
      allow write: if cmsEditor() && validImage("image/webp");
    }

    match /users/{userId}/profile/{fileName} {
      allow read: if signedIn() && (request.auth.uid == userId || request.auth.token.role == "admin");
      allow write: if signedIn()
        && (request.auth.uid == userId || request.auth.token.role == "admin")
        && validImage("image/webp");
    }
  }
}
